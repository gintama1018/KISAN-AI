# ─────────────────────────────────────────────────────────────────────────────
# KISAN AI — Environment Configuration
# Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────────────────────

# AgroMonitoring API Key (60 free calls/day)
# Register at: https://agromonitoring.com
AGRO_API_KEY=your_agromonitoring_key_here

# Twilio (WhatsApp alerts — free trial at https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Flask secret key (change in production)
FLASK_SECRET_KEY=kisan-ai-secret-key-change-in-production

# Open-Meteo (NO KEY NEEDED — leave blank)
# NASA POWER  (NO KEY NEEDED — leave blank)
# ISRO Bhuvan WMS (NO KEY NEEDED for basic layers)

# Optional: Google Translate fallback
# GOOGLE_TRANSLATE_API_KEY=your_key_here

# Alert output file (Pathway writes here, Flask reads here)
ALERTS_FILE=/tmp/kisan_alerts.jsonl
